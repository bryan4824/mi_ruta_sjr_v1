<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuarios · Mi Ruta SJR</title>
  <link rel="shortcut icon" href="/image/favicon.ico">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
    integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="css/style_lista_usuario.css" />
</head>

<body>

  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand me-2" href="#">
        <img src="/image/logo_sin_fondo.png" alt="Logo" />
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Sobre Nosotros</a></li>
        </ul>

        <div class="d-flex align-items-center gap-2">
          <button type="button" class="btn-nav-inicio" id="inicio-btn">← Inicio</button>
          <form action="/buscarContacto" method="POST" class="d-flex gap-2" role="search">
            <input class="search-input" name="username" type="search" placeholder="¿A quien deseas buscar?" />
            <button class="btn-buscar" type="submit">Buscar</button>
          </form>
        </div>
      </div>
    </div>
  </nav>

  <div class="usuarios-wrapper">

    <div class="page-header">
      <h1>
        <span>Panel de administración</span>
        Usuarios
      </h1>
    </div>
    <div class="page-divider"></div>

    <div class="tabla-card">
      <table class="tabla-usuarios">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Correo Electrónico</th>
            <th>Rol</th>
            <th>Descripción</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user=> { %>
            <tr>
              <td class="cell-id"><%= user._id %></td>
              <td class="cell-nombre"><%= user.username %></td>
              <td><%= user.email %></td>
              <td><span class="rol-badge"><%= user.role.rol %></span></td>
              <td><%= user.role.descripcion %></td>
              <td>
                <div class="acciones">
                  <a class="btn-editar" href="/editar/<%= user._id %>">Editar</a>
                  <!--/editar/:id viene de la ruta de edicion de la linea 44 del archivo rutas.js-->
                  <a class="btn-borrar" href="/eliminar/<%= user._id %>">Borrar</a>
                </div>
              </td>
            </tr>
          <%}) %>
        </tbody>
      </table>
    </div>

    <div class="tabla-footer">
      <a class="btn-volver" href="/admin">← Volver al dashboard</a>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmgJJBe7GYvRzVRE4h2q+RkLGt6c"
    crossorigin="anonymous"></script>

  <script>
    document.getElementById('inicio-btn').addEventListener('click', () => {
      fetch('/', {
        method: 'GET'
      })
        .then(() => {
          window.location.href = '/'
        })
    })
  </script>

</body>
</html>