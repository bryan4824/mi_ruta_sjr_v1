<div class="form-card">

    <div class="brand">
        <!-- <div class="brand-dot">🚌</div> -->
        <div class="brand-name">Mi Ruta <span>SJR</span></div>
    </div>

    <form id="login-form">
        <h2>Bienvenido<br>de nuevo</h2>
        <p class="form-sub">Ingresa para ver tus rutas</p>

        <label for="login-username">Username</label>
        <div class="input-wrapper">
            <input type="text" id="login-username" placeholder="Tu nombre de usuario" required>
            <i class="fa fa-user inp-icon"></i>
        </div>

        <label for="login-password">Password</label>
        <div class="input-wrapper">
            <input type="password" id="login-password" placeholder="••••••••" required>
            <i class="fa fa-lock inp-icon"></i>
        </div>

        <a href="/forgot-password" class="forgot">¿Olvidaste tu contraseña?</a>

        <button type="submit">Iniciar sesión</button>
        <span>&nbsp;</span>
    </form>

    <div class="form-divider"><span>o continúa con</span></div>

    <div class="social-row">
        <button class="m-0 btn btn-flat text-success social-btn">
            <i class="fab fa-facebook-f"></i>
        </button>
        <button class="m-0 btn btn-flat text-success social-btn">
            <i class="fab fa-twitter"></i>
        </button>
        <button class="m-0 btn btn-flat text-success social-btn">
            <i class="fab fa-google-plus-g"></i>
        </button>
    </div>

    <div class="text-center form-switch">
        <span>¿No tienes cuenta? <a href="/register" class="text-decoration-none text-primary">Regístrate aquí</a></span>
    </div>

</div>

