<div class="form-card">

    <div class="brand">
        <!-- <div class="brand-dot">🚌</div> -->
        <div class="brand-name">Mi Ruta <span>SJR</span></div>
    </div>

    <form id="register-form">
        <h2>Crear<br>cuenta</h2>
        <p class="form-sub">Regístrate para empezar</p>

        <label for="register-username">Username</label>
        <div class="input-wrapper">
            <input type="text" id="register-username" placeholder="Tu nombre de usuario" required>
            <i class="fa fa-user inp-icon"></i>
        </div>

        <label for="register-email">Email</label>
        <div class="input-wrapper">
            <input type="email" id="register-email" placeholder="tucorreo@email.com" required>
            <i class="fa fa-envelope inp-icon"></i>
        </div>

        <label for="register-password">Password</label>
        <div class="input-wrapper">
            <input type="password" id="register-password" placeholder="••••••••" required>
            <i class="fa fa-lock inp-icon"></i>
        </div>

        <label for="register-confirm-password">Confirm Password</label>
        <div class="input-wrapper">
            <input type="password" id="register-confirm-password" placeholder="••••••••" required>
            <i class="fa fa-lock inp-icon"></i>
        </div>

        <button type="submit">Registrarse</button>
        <span>&nbsp;</span>
    </form>

    <div class="form-divider"><span>o continúa con</span></div>

    <div class="my-3 d-flex justify-content-center social-row">
        <button class="m-0 btn btn-flat text-success social-btn">
            <i class="fab fa-facebook-f"></i>
        </button>
        <button class="m-0 btn btn-flat text-success social-btn">
            <i class="fab fa-twitter"></i>
        </button>
        <button class="m-0 btn btn-flat text-success social-btn">
            <i class="fab fa-google-plus-g"></i>
        </button>
    </div>

    <div class="text-center form-switch">
        <span>¿Ya tienes cuenta? <a href="/login" class="text-decoration-none text-primary">Inicia sesión aquí</a></span>
    </div>

</div>
