<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mis datos · Mi Ruta SJR</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <link rel="shortcut icon" href="/image/favicon.ico" />
  <link rel="stylesheet" href="css/style_perfil_datos.css" />
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand me-2" href="#">
        <img src="/image/logo_sin_fondo.png" alt="Logo" />
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
          <li class="nav-item"><a class="nav-link" href="#nosotros">Sobre Nosotros</a></li>
        </ul>

        <div class="d-flex align-items-center">
          <a class="btn-volver" href="/perfil">← Volver a perfil</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- CONTENIDO -->
  <div class="datos-wrapper">

    <div class="datos-header">
      <h1>
        <span>Mi cuenta</span>
        Mis datos
      </h1>
    </div>
    <div class="datos-divider"></div>

    <div class="datos-card">

      <!-- AVATAR -->
      <div class="avatar-block">
        <img src="<%= user.photoPerfil ? '/uploads/' + user.photoPerfil : 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>" alt="Foto de perfil" />
        <div class="user-name"><%= user.username %></div>
        <div class="user-sub">Usuario registrado</div>
      </div>

      <!-- DATOS -->
      <div class="datos-list">

        <div class="dato-row">
          <span class="dato-label">Nombre</span>
          <span class="dato-value <%= !user.nombre ? 'empty' : '' %>">
            <%= user.nombre || "No registrado" %>
          </span>
        </div>

        <div class="dato-row">
          <span class="dato-label">Edad</span>
          <span class="dato-value <%= !user.edad ? 'empty' : '' %>">
            <%= user.edad || "No registrada" %>
          </span>
        </div>

        <div class="dato-row">
          <span class="dato-label">Teléfono</span>
          <span class="dato-value <%= !user.telefono ? 'empty' : '' %>">
            <%= user.telefono || "No registrado" %>
          </span>
        </div>

        <div class="dato-row">
          <span class="dato-label">Correo</span>
          <span class="dato-value"><%= user.email %></span>
        </div>

        <div class="dato-row">
          <span class="dato-label">ID</span>
          <span class="dato-value id-val"><%= user._id %></span>
        </div>

      </div>

      <!-- ACCIÓN -->
      <div class="card-actions">
        <a href="/perfil" class="btn-editar-perfil">Editar perfil</a>
      </div>

    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="container text-center">
      <p class="mb-1">© 2025 Mi Ruta SJR</p>
      <a href="/terminos" class="text-decoration-none mx-2">Términos</a>
      <a href="/privacidad" class="text-decoration-none mx-2">Privacidad</a>
      <a href="/faq" class="text-decoration-none mx-2">FAQ</a>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
