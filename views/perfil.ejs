<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Perfil · Mi Ruta SJR</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <link rel="shortcut icon" href="/image/favicon.ico" />
  <link rel="stylesheet" href="css/style_perfil.css" />
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand me-2" href="#">
        <img src="/image/logo_sin_fondo.png" alt="Logo" />
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
          <li class="nav-item"><a class="nav-link" href="#nosotros">Sobre Nosotros</a></li>
        </ul>

        <div class="d-flex align-items-center">
          <a class="btn-volver" href="/rutas">← Volver a rutas</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- CONTENIDO -->
  <div class="perfil-wrapper">

    <!-- ENCABEZADO -->
    <div class="perfil-header">
      <h1>
        <span>Mi cuenta</span>
        Perfil
      </h1>
    </div>
    <div class="perfil-divider"></div>

    <!-- LAYOUT -->
    <div class="perfil-layout">

      <!-- SIDEBAR -->
      <div class="perfil-sidebar">
        <div class="avatar-wrap">
          <img src="<%= user.photoPerfil ? '/uploads/' + user.photoPerfil : 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>" alt="Foto de perfil" />
          <div class="avatar-name"><%= user.username %></div>
          <div class="avatar-sub">Usuario registrado</div>
        </div>

        <ul class="side-nav">
          <li><a href="#" class="active">Dashboard</a></li>
          <li><a href="/datosUsuario">Mis datos</a></li>
          <li><a href="/ajustes_usuario">Ajustes</a></li>
          <li><a href="/login" class="danger" id="logout-btn">Cerrar sesión</a></li>
        </ul>
      </div>

      <!-- FORMULARIO -->
      <div class="perfil-form-card">
        <h3>Editar perfil</h3>

        <form action="/SolicitarDatos" method="POST" enctype="multipart/form-data">

          <div class="form-section-label">Información personal</div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Nombre de usuario</label>
              <input type="text" name="username" class="form-control" placeholder="Tu nombre de usuario" value="<%= user.username %>" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Nombre</label>
              <input type="text" name="nombre" class="form-control" placeholder="Tu nombre completo" value="<%= user.nombre %>" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Edad</label>
              <input type="number" name="edad" class="form-control" placeholder="Tu edad" value="<%= user.edad %>" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Correo electrónico</label>
              <input type="email" class="form-control" placeholder="correo@example.com" value="<%= user.email %>" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Teléfono</label>
              <input type="tel" name="telefono" class="form-control" placeholder="Número de teléfono" value="<%= user.telefono %>" />
            </div>
          </div>

          <div class="form-section-label">Seguridad</div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Contraseña nueva</label>
              <input type="password" class="form-control" placeholder="••••••" />
            </div>

            <div class="col-md-6">
              <label class="form-label">Confirmar contraseña</label>
              <input type="password" class="form-control" placeholder="••••••" />
            </div>
          </div>

          <div class="form-section-label">Foto de perfil</div>

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label" for="foto">Seleccionar imagen</label>
              <input type="file" id="foto" name="foto" class="form-control" />
            </div>
          </div>

          <button type="submit" class="btn-guardar">Guardar cambios</button>

        </form>
      </div>

    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="container text-center">
      <p class="mb-1">© 2025 Mi Ruta SJR</p>
      <a href="/terminos" class="text-decoration-none mx-2">Términos</a>
      <a href="/privacidad" class="text-decoration-none mx-2">Privacidad</a>
      <a href="/faq" class="text-decoration-none mx-2">FAQ</a>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        fetch('/logout', { method: 'POST' })
          .then(() => { window.location.href = '/login'; });
      });
    }
  </script>
</body>
</html>