<style>
/* ── HERO ── */
.hero-dynamic {
  background: #ffe35a;
  min-height: 88vh;
  position: relative;
  overflow: hidden;
  color: #333;
  display: flex;
  flex-direction: column;
}

.hero-container { flex: 1; }

.hero-row {
  min-height: 75vh;
  padding: 60px 0 120px;
}

.animate-text { animation: fadeInUp 1.5s ease forwards; }
@keyframes fadeInUp {
  0%   { opacity:0; transform:translateY(21px); }
  100% { opacity:1; transform:translateY(0); }
}

.hover-scale:hover { transform: scale(1.05); transition: 0.3s; }

.logo-container .hero-img {
  max-width: 470px;
  width: 110%;
  height: auto;
}

.content-area, .logo-container { position: relative; z-index: 5; }

/* ── CALLE ── */
.street-lane {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 56px;
  background: #c8a040;
  z-index: 2;
}
.lane-line {
  position: absolute;
  top: 50%; left: 0; right: 0;
  height: 3px;
  background: repeating-linear-gradient(
    90deg,
    #fff 0px, #fff 40px,
    transparent 40px, transparent 80px
  );
  transform: translateY(-50%);
}

/* ── ICONOS EN CALLE ── */
.street-icon {
  position: absolute;
  bottom: 47.5px; /*posicion en y de icnos*/
  z-index: 3;
  width: 60px;
  display: block;
  transform: translateY(0);
}

.svg-stop { left: 15%; width: 60px; }
.svg-shop { left: 62%; width: 70px; }

/* ── BUS ── */
.svg-bus {
  position: absolute;
  bottom: 10px;
  width: 90px;
  z-index: 7;
  animation: busRide 18s linear infinite;
}

@keyframes busRide {
  0%   { left: -12%; }
  13%  { left: 13%;  }   /* llega a parada */
  18%  { left: 13%;  }   /* espera */
  58%  { left: 58%;  }   /* llega a negocio */
  63%  { left: 58%;  }   /* espera */
  100% { left: 115%; }
}

── FLOTANTES ──
.floating {
  position: absolute;
  width: 70px;
  z-index: 2;
}
.svg-ticket { top: 15%; right: 8%; }
.svg-bag    { top: 55%; right: 5%; }

/* ── CANVAS ── */
#dynamicCanvas {
  pointer-events: none;
  z-index: 1;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .hero-row { padding: 40px 0 110px; min-height: auto; }

  .logo-container { display: none; }

  .hero-dynamic { min-height: auto; }

  .svg-bus   { width: 54px; }
  .svg-stop  { width: 28px; bottom: 46px; }
  .svg-shop  { width: 34px; bottom: 46px; }

  .street-lane { height: 46px; }

  .floating { width: 48px; }
  .svg-ticket { top: 10%; right: 4%; }
  .svg-bag    { display: none; }

  h1.display-4 { font-size: 2rem; }
}

@media (max-width: 480px) {
  .svg-bus  { width: 44px; }
  .svg-stop { left: 36%; width: 24px; bottom: 37px; }
  .svg-shop { left: 62%; width: 28px; bottom: 37px; }
  .street-lane { height: 40px; }
  h1.display-4 { font-size: 1.7rem; }
}
</style>

<script>
const canvas = document.getElementById('dynamicCanvas');
const ctx = canvas.getContext('2d');

function resizeCanvas() {
  canvas.width  = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

// Flotantes (solo en desktop)
const floatingEls = [
  document.querySelector('.svg-ticket'),
  document.querySelector('.svg-bag')
].filter(Boolean);

const floaters = floatingEls.map(el => {
  const rect = el.getBoundingClientRect();
  return {
    el,
    x: rect.left,
    y: rect.top,
    vx: (Math.random() - 0.5) * 0.25,
    vy: (Math.random() - 0.5) * 0.25,
  };
});

function moveFloaters() {
  if (window.innerWidth < 768) { requestAnimationFrame(moveFloaters); return; }
  floaters.forEach(f => {
    f.x += f.vx;
    f.y += f.vy;
    if (f.x < 0 || f.x > window.innerWidth  - 80) f.vx *= -1;
    if (f.y < 0 || f.y > window.innerHeight - 80) f.vy *= -1;
    f.el.style.transform = `translate(${f.vx > 0 ? 0 : 0}px,0) rotate(${Math.sin(Date.now()/900)*8}deg)`;
  });
  requestAnimationFrame(moveFloaters);
}
moveFloaters();

// Partículas
const particles = [];
const colors = ['#FFD600','#FF9800','#FF3D00','#FFC107','#FFF176'];
for (let i = 0; i < 45; i++) {
  particles.push({
    x: Math.random() * window.innerWidth,
    y: Math.random() * window.innerHeight,
    radius: 4 + Math.random() * 9,
    angle:  Math.random() * Math.PI * 2,
    speed:  0.4 + Math.random() * 0.9,
    color:  colors[Math.floor(Math.random() * colors.length)],
    sway:   Math.random() * 0.4
  });
}

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  particles.forEach(p => {
    p.x += Math.cos(p.angle) * p.speed;
    p.y += Math.sin(p.angle) * p.speed + Math.sin(p.angle * 5) * p.sway;
    if (p.x < 0) p.x = canvas.width;
    if (p.x > canvas.width)  p.x = 0;
    if (p.y < 0) p.y = canvas.height;
    if (p.y > canvas.height) p.y = 0;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
    ctx.fillStyle = hexToRgba(p.color, 0.45);
    ctx.fill();
  });
  requestAnimationFrame(draw);
}
draw();

function hexToRgba(hex, a) {
  hex = hex.replace('#', '');
  const n = parseInt(hex, 16);
  return `rgba(${(n>>16)&255},${(n>>8)&255},${n&255},${a})`;
}
</script>


