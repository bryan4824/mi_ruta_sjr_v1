<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
  integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmgJJBe7GYvRzVRE4h2q+RkLGt6c"
  crossorigin="anonymous"></script>

  <script>
    //BUSCADOR
    function filtrarRuta(val) {
      const cards = document.querySelectorAll('.card');
      const num   = val.trim();

      if (!num) { cards.forEach(c => c.style.display = ''); document.getElementById('sinResultados').style.display = 'none'; return; }

      let encontrado = false;
      cards.forEach(c => {
        const badge = c.querySelector('.route-badge');
        if (badge && badge.textContent.trim() === num) {
          c.style.display = '';
          encontrado = true;
        } else {
          c.style.display = 'none';
        }
      });

      const sr = document.getElementById('sinResultados');
      document.getElementById('numBuscado').textContent = num;
      sr.style.display = encontrado ? 'none' : 'block';
    }

    function limpiarBusqueda() {
      document.getElementById('inputRuta').value = '';
      document.querySelectorAll('.card').forEach(c => c.style.display = '');
      document.getElementById('sinResultados').style.display = 'none';
    }
    // ✅ LocalStorage para guardar favoritos
    document.addEventListener("DOMContentLoaded", () => {
      const cards = document.querySelectorAll('.ruta-card');

      cards.forEach(card => {
        const id = card.getAttribute('data-id');
        const star = card.querySelector('.fav-star');

        if (localStorage.getItem(id) === "true") {
          star.classList.add('active');
        }

        star.addEventListener('click', () => {
          star.classList.toggle('active');
          localStorage.setItem(id, star.classList.contains('active'));
        });
      });
    });
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        fetch('/logout', { method: 'POST' })
          .then(() => { window.location.href = '/login'; });
      });
    }
     const logoutMini = document.getElementById('logout-mini');
              if (logoutMini) {
                logoutMini.addEventListener('click', () => {
                  fetch('/logout', { method: 'POST' })
                    .then(() => { window.location.href = '/login'; });
                });
              }
  </script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

